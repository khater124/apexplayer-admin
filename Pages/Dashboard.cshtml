@page
@model ApexPlayerPanel.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>Dashboard</h1>
    <p>Overview of all devices and subscription status.</p>
</div>

<!-- Stats grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(255,215,0,.1); color:#FFD700;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <div class="stat-value">@Model.TotalDevices</div>
        <div class="stat-label">Total Devices</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(46,213,115,.1); color:#2ed573;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="stat-value" style="color:#2ed573;">@Model.ActiveToday</div>
        <div class="stat-label">Active Today</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(116,185,255,.1); color:#74b9ff;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="stat-value" style="color:#74b9ff;">@Model.ActiveThisWeek</div>
        <div class="stat-label">Active This Week</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(253,203,110,.1); color:#fdcb6e;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="stat-value" style="color:#fdcb6e;">@Model.TrialDevices</div>
        <div class="stat-label">On Trial</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(255,140,0,.1); color:#ff8c00;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="stat-value" style="color:#ff8c00;">@Model.ExpiringSoon</div>
        <div class="stat-label">Expiring Soon (≤3d)</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(231,76,60,.1); color:#e74c3c;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <div class="stat-value" style="color:#e74c3c;">@Model.ExpiredDevices</div>
        <div class="stat-label">Expired</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(231,76,60,.08); color:#c0392b;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="stat-value" style="color:#c0392b;">@Model.BlockedDevices</div>
        <div class="stat-label">Blocked</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(255,215,0,.08); color:#FFD700;">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="stat-value" style="color:#FFD700;">@Model.UnlimitedDevices</div>
        <div class="stat-label">Unlimited</div>
    </div>
</div>

<!-- Recently active -->
<div class="panel-card mt-4">
    <div class="panel-card-title">Recently Active Devices</div>
    @if (!Model.RecentDevices.Any())
    {
        <div class="empty-state">No device has connected yet.</div>
    }
    else
    {
        <div class="table-responsive">
        <table class="dark-table">
            <thead>
                <tr>
                    <th>MAC Address</th>
                    <th>Device ID</th>
                    <th>Last Seen</th>
                    <th>Status</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.RecentDevices)
                {
                    <tr>
                        <td><span class="mac-code">@d.Mac</span></td>
                        <td style="color:#aaa;">@d.DeviceId</td>
                        <td style="color:#666; font-size:13px;">@d.LastSeen</td>
                        <td>
                            @if (d.IsBlocked)
                            {
                                <span class="status-badge blocked">Blocked</span>
                            }
                            else if (d.IsExpired)
                            {
                                <span class="status-badge expired">Expired</span>
                            }
                            else
                            {
                                <span class="status-badge active">Active</span>
                            }
                        </td>
                        <td style="text-align:right;">
                            <a asp-page="/DeviceDetail" asp-route-mac="@d.Mac" asp-route-deviceId="@d.DeviceId"
                               class="btn-primary-sm">Manage</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
